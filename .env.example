# ─────────────────────────────────────────────────────────────────────────────
# envio_ga-indexer — environment configuration
# Copy to `.env` and fill in the ClickHouse credentials + GraphQL Bearer token.
# Put REAL secrets only in `.env` (gitignored), never in `.env.example`.
# ─────────────────────────────────────────────────────────────────────────────

# ── GraphQL source (Hasura / Envio HyperIndex) ──────────────────────────────
# Auth is a Bearer token → sent as:  Authorization: Bearer <GRAPHQL_API_KEY>
GRAPHQL_ENDPOINT=https://gnosis-e702590.dedicated.hyperindex.xyz/v1/graphql
GRAPHQL_API_KEY=
GRAPHQL_AUTH_HEADER=Authorization
GRAPHQL_AUTH_SCHEME=Bearer             # prefixed to the token; set empty for a raw header value

# ── ClickHouse (managed instance — REQUIRED) ────────────────────────────────
# clickhouse-connect uses the HTTP interface: 8123 (plain) or 8443/443 (secure/TLS).
CLICKHOUSE_HOST=
CLICKHOUSE_USER=
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=envio_ga
CLICKHOUSE_PORT=8443
CLICKHOUSE_SECURE=true

# ── Pagination & throughput (single dedicated Hasura — be gentle) ───────────
PAGE_SIZE=1000                 # hard server cap is 1000; do not exceed
BACKFILL_CONCURRENCY=4         # disjoint entity/sub-chunk workers
GQL_MAX_RPS=10                 # shared token-bucket against Hasura
GQL_MAX_RETRIES=5              # exponential backoff + jitter on 429/5xx/timeout
GQL_TIMEOUT=120                # per-request total timeout (seconds)

# ── Entity selection ────────────────────────────────────────────────────────
# Empty = all enabled entities. Comma-separated lower_snake names to restrict, e.g.
# ENABLED_ENTITIES=transfer,avatar,metri_order
ENABLED_ENTITIES=

# ── Continuous ingestion & reconcile cadence ────────────────────────────────
POLL_INTERVAL=30               # realtime tick (seconds)
REALTIME_OVERLAP_BLOCKS=5      # re-read boundary blocks (reorg/tie safety)
RESCAN_INTERVAL_S=300          # full_rescan sweep for cursorless mutable entities
RECONCILE_INTERVAL_S=86400     # INV-1 delete-detection id-diff (daily)

# ── Raw audit log retention ─────────────────────────────────────────────────
RAW_TTL_DAYS=0                 # 0 = no TTL (keep full mutation history forever)

# ── Observability & logging ─────────────────────────────────────────────────
METRICS_ENABLED=true
METRICS_PORT=9090
LOG_LEVEL=INFO
# FORCE_JSON_LOGS=false        # structlog JSON output (for log shippers)
